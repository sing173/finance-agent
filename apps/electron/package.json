{
  "name": "finance-agent-electron",
  "version": "0.1.0",
  "description": "财务智能助手 - 智能银行对账桌面应用",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "dev:renderer": "cd ../renderer && npm run dev",
    "dev:electron": "npm run build && electron .",
    "build": "tsc",
    "package": "electron-builder --win",
    "package:python": "cd ../python && pyinstaller bridge.spec --onefile --clean",
    "package:all": "npm run package:python && npm run package"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.finance-assistant.app",
    "productName": "FinanceAssistant",
    "directories": {
      "output": "../../release"
    },
    "asar": false,
    "files": [
      "dist/**/*.js",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../python/dist",
        "to": "python"
      },
      {
        "from": "../renderer/dist",
        "to": "renderer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": "cert/finance-assistant-test.pfx",
      "certificatePassword": "FinanceAssistant123!",
      "signDlls": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
