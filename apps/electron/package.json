{
  "name": "finance-agent-electron",
  "version": "0.3.1",
  "description": "财务智能助手 - 银行对账桌面应用",
  "author": "zungen",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "dev:renderer": "cd ../renderer && npm run dev",
    "dev:electron": "electron .",
    "build": "node copy-to-ohos.js",
    "build:ohos": "node copy-to-ohos.js",
    "package": "electron-builder --win",
    "package:python": "cd ../python && python -m pyinstaller bridge.spec --onefile --clean",
    "package:all": "npm run package:python && npm run package",
    "dist:ohos": "electron-builder-ohos --ohos"
  },
  "devDependencies": {
    "@electron-ohos/electron-builder": "^26.8.5",
    "7zip-bin": "^5.2.0",
    "electron": "32.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zungen.financeassistant",
    "productName": "FinanceAssistant",
    "directories": {
      "output": "../../release"
    },
    "asar": false,
    "files": [
      "src/**/*.js",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../python/dist/bridge.exe",
        "to": "python/bridge.exe"
      },
      {
        "from": "../renderer/dist",
        "to": "renderer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "ohos": {
      "icon": "./icon.png",
      "target": [
        "hap"
      ],
      "hvigorwPath": "D:/Development/DevEco Studio/tools/hvigor/bin",
      "ohpmPath": "D:/Development/DevEco Studio/tools/ohpm/bin",
      "sdkPath": "D:/Development/DevEco Studio/sdk",
      "ohosHapPath": "D:/HarmonyDevelopment/electron-harmony-sdk/v34.8.3-20260612.1-release/libelectron/ohos_hap",
      "certPath": "D:/WorkSpace/zungen/finance-agent/apps/electron/cert/financeassistant_ohos.cer",
      "profile": "D:/WorkSpace/zungen/finance-agent/apps/electron/cert/financeassistant_profileRelease.p7b",
      "keyAlias": "financeassistant",
      "keyPassword": "zungen@123",
      "storeFile": "D:/WorkSpace/zungen/finance-agent/apps/electron/cert/financeassistant.p12",
      "storePassword": "zungen@123"
    }
  }
}
